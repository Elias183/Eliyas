import sqlite3
import datetime

DB = "database.db"

def init_db():
    conn = sqlite3.connect(DB)
    c = conn.cursor()
    c.execute("""CREATE TABLE IF NOT EXISTS items (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        starting_qty INTEGER,
        threshold INTEGER
    )""")
    c.execute("""CREATE TABLE IF NOT EXISTS incoming (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        item_id INTEGER,
        qty INTEGER,
        date TEXT
    )""")
    c.execute("""CREATE TABLE IF NOT EXISTS sales (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        item_id INTEGER,
        qty INTEGER,
        date TEXT
    )""")
    conn.commit()
    conn.close()

def add_item(name, starting_qty, threshold):
    conn = sqlite3.connect(DB)
    c = conn.cursor()
    c.execute("INSERT INTO items (name, starting_qty, threshold) VALUES (?, ?, ?)",
              (name, starting_qty, threshold))
    conn.commit()
    conn.close()

def record_incoming(item_id, qty):
    conn = sqlite3.connect(DB)
    c = conn.cursor()
    c.execute("INSERT INTO incoming (item_id, qty, date) VALUES (?, ?, ?)",
              (item_id, qty, str(datetime.date.today())))
    conn.commit()
    conn.close()

def record_sale(item_id, qty):
    conn = sqlite3.connect(DB)
    c = conn.cursor()
    # compute remaining stock
    c.execute("SELECT starting_qty FROM items WHERE id=?", (item_id,))
    start = c.fetchone()[0]
    c.execute("SELECT SUM(qty) FROM incoming WHERE item_id=?", (item_id,))
    incoming = c.fetchone()[0] or 0
    c.execute("SELECT SUM(qty) FROM sales WHERE item_id=?", (item_id,))
    sold = c.fetchone()[0] or 0
    remaining = start + incoming - sold
    if qty > remaining:
        conn.close()
        return False, "Sale blocked: insufficient stock"
    c.execute("INSERT INTO sales (item_id, qty, date) VALUES (?, ?, ?)",
              (item_id, qty, str(datetime.date.today())))
    conn.commit()
    conn.close()
    return True, "Sale recorded"

def get_items():
    conn = sqlite3.connect(DB)
    c = conn.cursor()
    c.execute("SELECT * FROM items")
    items = c.fetchall()
    conn.close()
    return items

def get_alerts():
    conn = sqlite3.connect(DB)
    c = conn.cursor()
    alerts = []
    for item in get_items():
        item_id, name, start, threshold = item
        c.execute("SELECT SUM(qty) FROM incoming WHERE item_id=?", (item_id,))
        incoming = c.fetchone()[0] or 0
        c.execute("SELECT SUM(qty) FROM sales WHERE item_id=?", (item_id,))
        sold = c.fetchone()[0] or 0
        remaining = start + incoming - sold
        if remaining < threshold:
            alerts.append({"item": name, "remaining": remaining})
    conn.close()
    return alerts

